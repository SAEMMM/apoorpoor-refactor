generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LedgerType {
  income
  expense
}

enum LedgerCategory {
  salary
  bonus
  food
  cafe
  transport
  shopping
  living
  health
  culture
  gift
  etc
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  poorName String
  points   Int    @default(0)
  level    Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledger      Ledger?
  ledgerItems LedgerItem[]

  @@map("users")
}

model Ledger {
  id     String @id @default(cuid())
  userId String @unique
  name   String @default("가계부 이름")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("ledgers")
}

model LedgerItem {
  id        String         @id @default(cuid())
  userId    String
  name      String
  type      LedgerType
  category  LedgerCategory
  amount    Int
  date      DateTime       @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("ledger_items")
}
